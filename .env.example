# PostgreSQL (matches docker-compose defaults)
# Port 5433 avoids conflict with a local PostgreSQL on 5432
DATABASE_URL=postgresql+psycopg2://lawchat:lawchat@127.0.0.1:5433/lawchat

# openai | local
EMBEDDING_PROVIDER=local

# OpenAI: text-embedding-3-small (1536) or text-embedding-3-large (3072)
# Local: intfloat/multilingual-e5-large (1024) — good for Bulgarian
# If you change provider/model/dimension, re-run ingest (init_db recreates the table).
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024

OPENAI_API_KEY=

# Create tables + HNSW index on API startup (dev convenience)
INIT_DB_ON_STARTUP=true
